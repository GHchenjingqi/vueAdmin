{
  "name": "vue-admin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "reinstall": "npx -y rimraf node_modules server/node_modules package-lock.json server/package-lock.json",
    "install:all": "npm install && cd server && npm install",
    "dev": "cd server && npm run dev",
    "build": "vite build",
    "start": "cd server && npm run build && cross-env NODE_ENV=production node dist/app.js",
    "format": "prettier --write \"src/**/*.{vue,ts,js,css,scss,json}\"",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "test": "vitest run --coverage --silent",
    "test:watch": "vitest --silent",
    "test:fast": "vitest run --silent",
    "test:coverage": "vitest run --coverage --silent",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "migrate": "cd server && tsx scripts/migrate.ts up",
    "migrate:down": "cd server && tsx scripts/migrate.ts down",
    "migrate:seed": "cd server && tsx scripts/migrate.ts seed",
    "migrate:reset": "cd server && tsx scripts/migrate.ts reset",
    "migrate:status": "cd server && tsx scripts/migrate.ts status",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "test:e2e:report": "playwright show-report e2e-report",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "version:bump": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md",
    "benchmark": "vitest bench --run",
    "analyze": "cross-env ANALYZE=true vite build"
  },
  "lint-staged": {
    "src/**/*.{vue,ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,scss,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.0.0",
    "@iconify-json/ep": "^1.2.4",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^8.2.0",
    "conventional-changelog-cli": "^5.0.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "globals": "^17.7.0",
    "husky": "^9.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.101.0",
    "typescript-eslint": "^8.0.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.3.0",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@esbuild/win32-x64": "^0.25.0",
    "@sentry/browser": "^10.63.0",
    "@sentry/node": "^10.63.0",
    "@sentry/vue": "^10.63.0",
    "@types/nprogress": "^0.2.3",
    "@types/sortablejs": "^1.15.9",
    "axios": "^1.7.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.7.0",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.11.1",
    "katex": "^0.17.0",
    "marked": "^12.0.0",
    "md-editor-v3": "^6.5.3",
    "mermaid": "^11.16.0",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "selfsigned": "^5.5.0",
    "sortablejs": "^1.15.7",
    "umzug": "^3.8.3",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "web-vitals": "^5.3.0",
    "zod": "^3.25.76"
  },
  "performanceBudget": {
    "maxBundleSize": "500KB",
    "maxInitialJs": "300KB",
    "maxInitialCss": "100KB",
    "lighthouseScore": 90
  }
}