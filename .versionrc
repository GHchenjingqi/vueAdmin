{
  "types": [
    { "type": "feat", "section": "🚀 新功能 Features" },
    { "type": "fix", "section": "🐛 修复 Bug Fixes" },
    { "type": "perf", "section": "⚡ 性能优化 Performance" },
    { "type": "refactor", "section": "♻️ 重构 Refactoring" },
    { "type": "style", "section": "🎨 代码风格 Style" },
    { "type": "docs", "section": "📝 文档更新 Documentation" },
    { "type": "test", "section": "✅ 测试 Tests" },
    { "type": "build", "section": "📦 构建系统 Build" },
    { "type": "ci", "section": "🔧 CI/CD" },
    { "type": "chore", "section": "🧹 杂项 Chores" }
  ],
  "commitUrlFormat": "{{host}}/{{owner}}/{{repository}}/commit/{{hash}}",
  "compareUrlFormat": "{{host}}/{{owner}}/{{repository}}/compare/{{previousTag}}...{{currentTag}}"
}