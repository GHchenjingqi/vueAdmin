# ==================================
# 环境变量模板
# 复制此文件为 .env 或对应环境文件后修改
# ==================================

# -------------------- 前端配置 (Vite) --------------------
# 后端 API 基础地址（开发环境 Vite 中间件内嵌，一般无需设置）
# VITE_API_BASE_URL=http://localhost:5173/api

# 应用标题
VITE_APP_TITLE=通用管理系统

# 应用描述
VITE_APP_DESCRIPTION=基于 Vue 3 + Element Plus 的通用后台管理系统

# -------------------- 后端配置 (Express) --------------------
# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=vue_admin
DB_USER=root
DB_PASSWORD=changeme

# 服务端口
# 开发默认 5173（与 E2E / 本地访问一致）
# Docker / 生产常用 3000（与 k8s/docker-compose 一致）
SERVER_PORT=5173

# Docker Compose 宿主机映射端口（容器内固定 3000）
# SERVER_HOST_PORT=3000

# JWT 密钥（生产环境必须修改为强随机字符串）
JWT_SECRET=your_strong_random_secret_here

# CORS / CSRF Origin 白名单（逗号分隔，生产必填）
# 示例: https://admin.example.com,https://www.example.com
ALLOWED_ORIGINS=https://localhost:5173,http://localhost:5173,https://127.0.0.1:5173,http://127.0.0.1:5173

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 验证码开关（也可在系统设置中配置 captcha_enabled）: true | false
CAPTCHA_ENABLED=true

# 文件上传大小限制 (MB)
UPLOAD_MAX_SIZE=10

# 上传文件存储路径
UPLOAD_PATH=./server/uploads

# Sentry 错误监控 DSN（生产环境使用）
# SENTRY_DSN=https://xxx@sentry.io/xxx

# -------------------- Redis 配置（多实例限流） --------------------
# 启用 Redis（设为 true 启用，空或 false 则使用内存降级）
REDIS_ENABLED=false
# Redis 连接地址（支持 Sentinel/Cluster 格式）
REDIS_URL=redis://localhost:6379
